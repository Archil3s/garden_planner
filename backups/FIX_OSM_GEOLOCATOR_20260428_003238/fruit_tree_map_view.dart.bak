import 'dart:convert';

import 'package:flutter/material.dart';
import 'package:flutter_map/flutter_map.dart';
import 'package:geolocator/geolocator.dart';
import 'package:latlong2/latlong.dart';
import 'package:shared_preferences/shared_preferences.dart';

class FruitTreeMapView extends StatefulWidget {
  const FruitTreeMapView({super.key});

  @override
  State<FruitTreeMapView> createState() => _FruitTreeMapViewState();
}

class _FruitTreeMapViewState extends State<FruitTreeMapView> {
  static const String storageKey = 'fruit_tree_osm_markers_v1';

  final MapController mapController = MapController();
  final List<_FruitTreeMarker> markers = [];

  LatLng? currentPosition;
  bool loadingLocation = true;
  bool permissionDenied = false;

  @override
  void initState() {
    super.initState();
    _loadMarkers();
    _loadCurrentLocation();
  }

  Future<void> _loadMarkers() async {
    final prefs = await SharedPreferences.getInstance();
    final raw = prefs.getString(storageKey);

    if (raw == null || raw.trim().isEmpty) return;

    final decoded = jsonDecode(raw) as List<dynamic>;

    setState(() {
      markers
        ..clear()
        ..addAll(
          decoded.map((item) {
            return _FruitTreeMarker.fromJson(
              Map<String, dynamic>.from(item as Map),
            );
          }),
        );
    });
  }

  Future<void> _saveMarkers() async {
    final prefs = await SharedPreferences.getInstance();

    await prefs.setString(
      storageKey,
      jsonEncode(markers.map((marker) => marker.toJson()).toList()),
    );
  }

  Future<void> _loadCurrentLocation() async {
    setState(() {
      loadingLocation = true;
      permissionDenied = false;
    });

    final serviceEnabled = await Geolocator.isLocationServiceEnabled();

    if (!serviceEnabled) {
      setState(() {
        loadingLocation = false;
        permissionDenied = true;
      });
      return;
    }

    var permission = await Geolocator.checkPermission();

    if (permission == LocationPermission.denied) {
      permission = await Geolocator.requestPermission();
    }

    if (permission == LocationPermission.denied ||
        permission == LocationPermission.deniedForever) {
      setState(() {
        loadingLocation = false;
        permissionDenied = true;
      });
      return;
    }

    final position = await Geolocator.getCurrentPosition(
      desiredAccuracy: LocationAccuracy.high,
    );

    final next = LatLng(position.latitude, position.longitude);

    setState(() {
      currentPosition = next;
      loadingLocation = false;
      permissionDenied = false;
    });

    mapController.move(next, 17);
  }

  Future<void> _addMarkerAt(LatLng point) async {
    final marker = await _openMarkerSheet(initialPosition: point);

    if (marker == null) return;

    setState(() {
      markers.add(marker);
    });

    await _saveMarkers();
  }

  Future<void> _editMarker(_FruitTreeMarker marker) async {
    final updated = await _openMarkerSheet(
      existing: marker,
      initialPosition: marker.position,
    );

    if (updated == null) return;

    setState(() {
      final index = markers.indexWhere((item) => item.id == marker.id);

      if (index != -1) {
        markers[index] = updated;
      }
    });

    await _saveMarkers();
  }

  Future<void> _deleteMarker(_FruitTreeMarker marker) async {
    setState(() {
      markers.removeWhere((item) => item.id == marker.id);
    });

    await _saveMarkers();
  }

  Future<_FruitTreeMarker?> _openMarkerSheet({
    _FruitTreeMarker? existing,
    required LatLng initialPosition,
  }) async {
    final typeController = TextEditingController(text: existing?.type ?? '');
    final notesController = TextEditingController(text: existing?.notes ?? '');

    final result = await showModalBottomSheet<_FruitTreeMarker>(
      context: context,
      isScrollControlled: true,
      showDragHandle: true,
      backgroundColor: const Color(0xFFFFFBF4),
      builder: (context) {
        final bottomInset = MediaQuery.of(context).viewInsets.bottom;

        return Padding(
          padding: EdgeInsets.fromLTRB(16, 8, 16, bottomInset + 18),
          child: SafeArea(
            child: ListView(
              shrinkWrap: true,
              children: [
                Text(
                  existing == null ? 'Add fruit tree' : 'Edit fruit tree',
                  style: Theme.of(
                    context,
                  ).textTheme.titleLarge?.copyWith(fontWeight: FontWeight.w900),
                ),
                const SizedBox(height: 12),
                TextField(
                  controller: typeController,
                  textCapitalization: TextCapitalization.words,
                  decoration: const InputDecoration(
                    labelText: 'Fruit tree type',
                    hintText: 'Apple, pear, plum, almond, fig...',
                    border: OutlineInputBorder(),
                  ),
                ),
                const SizedBox(height: 10),
                Wrap(
                  spacing: 8,
                  runSpacing: 8,
                  children: [
                    for (final type in const [
                      'Apple',
                      'Pear',
                      'Plum',
                      'Cherry',
                      'Fig',
                      'Almond',
                      'Peach',
                      'Lemon',
                      'Orange',
                      'Mulberry',
                      'Olive',
                      'Walnut',
                    ])
                      ActionChip(
                        label: Text(type),
                        onPressed: () {
                          typeController.text = type;
                        },
                      ),
                  ],
                ),
                const SizedBox(height: 12),
                TextField(
                  controller: notesController,
                  minLines: 2,
                  maxLines: 4,
                  textCapitalization: TextCapitalization.sentences,
                  decoration: const InputDecoration(
                    labelText: 'Notes',
                    hintText: 'Condition, access, fruiting season...',
                    border: OutlineInputBorder(),
                  ),
                ),
                const SizedBox(height: 12),
                Text(
                  'Location: ${initialPosition.latitude.toStringAsFixed(6)}, '
                  '${initialPosition.longitude.toStringAsFixed(6)}',
                  style: const TextStyle(fontSize: 12),
                ),
                const SizedBox(height: 16),
                FilledButton.icon(
                  onPressed: () {
                    final type = typeController.text.trim();

                    if (type.isEmpty) return;

                    Navigator.of(context).pop(
                      _FruitTreeMarker(
                        id:
                            existing?.id ??
                            'fruit-${DateTime.now().microsecondsSinceEpoch}',
                        type: type,
                        notes: notesController.text.trim(),
                        latitude: initialPosition.latitude,
                        longitude: initialPosition.longitude,
                        createdAt: existing?.createdAt ?? DateTime.now(),
                      ),
                    );
                  },
                  icon: const Icon(Icons.save_outlined),
                  label: Text(
                    existing == null ? 'Save marker' : 'Save changes',
                  ),
                ),
                if (existing != null) ...[
                  const SizedBox(height: 8),
                  OutlinedButton.icon(
                    onPressed: () {
                      Navigator.of(context).pop();
                      _deleteMarker(existing);
                    },
                    icon: const Icon(Icons.delete_outline),
                    label: const Text('Delete marker'),
                  ),
                ],
              ],
            ),
          ),
        );
      },
    );

    typeController.dispose();
    notesController.dispose();

    return result;
  }

  void _openMarkerList() {
    showModalBottomSheet<void>(
      context: context,
      showDragHandle: true,
      backgroundColor: const Color(0xFFFFFBF4),
      builder: (context) {
        return SafeArea(
          child: markers.isEmpty
              ? const Padding(
                  padding: EdgeInsets.all(18),
                  child: Text(
                    'No fruit tree markers yet. Long-press the map to add one.',
                  ),
                )
              : ListView.separated(
                  padding: const EdgeInsets.fromLTRB(12, 8, 12, 18),
                  itemCount: markers.length,
                  separatorBuilder: (_, __) => const SizedBox(height: 8),
                  itemBuilder: (context, index) {
                    final marker = markers[index];

                    return Card(
                      elevation: 0,
                      child: ListTile(
                        leading: const Icon(Icons.park_outlined),
                        title: Text(
                          marker.type,
                          style: const TextStyle(fontWeight: FontWeight.w900),
                        ),
                        subtitle: Text(
                          marker.notes.isEmpty
                              ? '${marker.latitude.toStringAsFixed(5)}, ${marker.longitude.toStringAsFixed(5)}'
                              : marker.notes,
                        ),
                        trailing: const Icon(Icons.chevron_right),
                        onTap: () {
                          Navigator.of(context).pop();
                          mapController.move(marker.position, 18);
                          _editMarker(marker);
                        },
                      ),
                    );
                  },
                ),
        );
      },
    );
  }

  @override
  Widget build(BuildContext context) {
    final start =
        currentPosition ??
        (markers.isNotEmpty
            ? markers.first.position
            : const LatLng(-41.5111, 173.9547));

    return Scaffold(
      backgroundColor: const Color(0xFFF7F2EA),
      body: SafeArea(
        child: Column(
          children: [
            _FruitMapHeader(
              markerCount: markers.length,
              loadingLocation: loadingLocation,
              permissionDenied: permissionDenied,
              onLocate: _loadCurrentLocation,
              onList: _openMarkerList,
            ),
            Expanded(
              child: Padding(
                padding: const EdgeInsets.fromLTRB(8, 0, 8, 8),
                child: ClipRRect(
                  borderRadius: BorderRadius.circular(22),
                  child: Stack(
                    children: [
                      FlutterMap(
                        mapController: mapController,
                        options: MapOptions(
                          initialCenter: start,
                          initialZoom:
                              currentPosition == null && markers.isEmpty
                              ? 12
                              : 17,
                          onLongPress: (tapPosition, point) {
                            _addMarkerAt(point);
                          },
                        ),
                        children: [
                          TileLayer(
                            urlTemplate:
                                'https://tile.openstreetmap.org/{z}/{x}/{y}.png',
                            userAgentPackageName: 'com.example.garden_planner',
                          ),
                          MarkerLayer(
                            markers: [
                              if (currentPosition != null)
                                Marker(
                                  point: currentPosition!,
                                  width: 44,
                                  height: 44,
                                  child: const _LocationMarker(),
                                ),
                              for (final marker in markers)
                                Marker(
                                  point: marker.position,
                                  width: 54,
                                  height: 54,
                                  child: GestureDetector(
                                    onTap: () => _editMarker(marker),
                                    child: const _FruitMarkerIcon(),
                                  ),
                                ),
                            ],
                          ),
                        ],
                      ),
                      Positioned(
                        left: 12,
                        right: 12,
                        top: 12,
                        child: Card(
                          elevation: 0,
                          color: Colors.white.withValues(alpha: 0.92),
                          shape: RoundedRectangleBorder(
                            borderRadius: BorderRadius.circular(18),
                          ),
                          child: const Padding(
                            padding: EdgeInsets.all(10),
                            child: Text(
                              'Long-press the map to mark a fruit tree.',
                              style: TextStyle(fontWeight: FontWeight.w800),
                            ),
                          ),
                        ),
                      ),
                      Positioned(
                        right: 12,
                        bottom: 12,
                        child: Column(
                          children: [
                            FloatingActionButton.small(
                              heroTag: 'fruit-map-list',
                              onPressed: _openMarkerList,
                              child: const Icon(Icons.list),
                            ),
                            const SizedBox(height: 10),
                            FloatingActionButton.small(
                              heroTag: 'fruit-map-location',
                              onPressed: _loadCurrentLocation,
                              child: const Icon(Icons.my_location),
                            ),
                          ],
                        ),
                      ),
                    ],
                  ),
                ),
              ),
            ),
          ],
        ),
      ),
    );
  }
}

class _FruitMapHeader extends StatelessWidget {
  const _FruitMapHeader({
    required this.markerCount,
    required this.loadingLocation,
    required this.permissionDenied,
    required this.onLocate,
    required this.onList,
  });

  final int markerCount;
  final bool loadingLocation;
  final bool permissionDenied;
  final VoidCallback onLocate;
  final VoidCallback onList;

  @override
  Widget build(BuildContext context) {
    final status = permissionDenied
        ? 'Location permission needed'
        : loadingLocation
        ? 'Finding location...'
        : '$markerCount fruit tree markers';

    return Padding(
      padding: const EdgeInsets.fromLTRB(12, 8, 12, 8),
      child: Card(
        elevation: 0,
        color: Colors.white,
        shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(22)),
        child: Padding(
          padding: const EdgeInsets.all(12),
          child: Row(
            children: [
              const Icon(Icons.map_outlined),
              const SizedBox(width: 10),
              Expanded(
                child: Text(
                  'Fruit Tree Map\n$status',
                  style: const TextStyle(fontWeight: FontWeight.w900),
                ),
              ),
              IconButton.outlined(
                onPressed: onList,
                icon: const Icon(Icons.list),
              ),
              const SizedBox(width: 6),
              IconButton.outlined(
                onPressed: onLocate,
                icon: const Icon(Icons.my_location),
              ),
            ],
          ),
        ),
      ),
    );
  }
}

class _FruitMarkerIcon extends StatelessWidget {
  const _FruitMarkerIcon();

  @override
  Widget build(BuildContext context) {
    return DecoratedBox(
      decoration: BoxDecoration(
        color: const Color(0xFF2E7D32),
        shape: BoxShape.circle,
        border: Border.all(color: Colors.white, width: 3),
        boxShadow: [
          BoxShadow(
            color: Colors.black.withValues(alpha: 0.25),
            blurRadius: 6,
            offset: const Offset(0, 3),
          ),
        ],
      ),
      child: const Center(
        child: Icon(Icons.park, color: Colors.white, size: 26),
      ),
    );
  }
}

class _LocationMarker extends StatelessWidget {
  const _LocationMarker();

  @override
  Widget build(BuildContext context) {
    return DecoratedBox(
      decoration: BoxDecoration(
        color: Colors.blue,
        shape: BoxShape.circle,
        border: Border.all(color: Colors.white, width: 3),
      ),
      child: const Center(
        child: Icon(Icons.my_location, color: Colors.white, size: 20),
      ),
    );
  }
}

class _FruitTreeMarker {
  const _FruitTreeMarker({
    required this.id,
    required this.type,
    required this.notes,
    required this.latitude,
    required this.longitude,
    required this.createdAt,
  });

  final String id;
  final String type;
  final String notes;
  final double latitude;
  final double longitude;
  final DateTime createdAt;

  LatLng get position => LatLng(latitude, longitude);

  Map<String, dynamic> toJson() {
    return {
      'id': id,
      'type': type,
      'notes': notes,
      'latitude': latitude,
      'longitude': longitude,
      'createdAt': createdAt.toIso8601String(),
    };
  }

  factory _FruitTreeMarker.fromJson(Map<String, dynamic> json) {
    return _FruitTreeMarker(
      id: json['id'] as String,
      type: json['type'] as String,
      notes: (json['notes'] as String?) ?? '',
      latitude: (json['latitude'] as num).toDouble(),
      longitude: (json['longitude'] as num).toDouble(),
      createdAt:
          DateTime.tryParse(json['createdAt'] as String? ?? '') ??
          DateTime.now(),
    );
  }
}
