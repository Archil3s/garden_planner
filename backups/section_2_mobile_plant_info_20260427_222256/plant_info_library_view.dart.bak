  List<String> _speciesChoices() {
    final scoped = activeCategory == _PlantInfoCategory.all
        ? _profiles
        : _profiles.where((profile) => profile.category == activeCategory);

    final values = <String>{
      'All species',
      for (final profile in scoped) _speciesForProfile(profile),
    }.toList();

    values.sort((a, b) {
      if (a == 'All species') return -1;
      if (b == 'All species') return 1;
      return a.compareTo(b);
    });

    return values;
  }

  bool _matchesSpecies(_PlantProfile profile) {
    if (activeSpeciesFilter == 'All species') return true;

    return _speciesForProfile(profile) == activeSpeciesFilter;
  }

  String _speciesForProfile(_PlantProfile profile) {
    final value = '${profile.key} ${profile.name} ${profile.family}'
        .toLowerCase();

    if (value.contains('broccoli') ||
        value.contains('cabbage') ||
        value.contains('cauliflower') ||
        value.contains('kale') ||
        value.contains('brussels') ||
        value.contains('brassica')) {
      return 'Brassica';
    }

    if (value.contains('lettuce') ||
        value.contains('spinach') ||
        value.contains('silverbeet') ||
        value.contains('chard') ||
        value.contains('rocket') ||
        value.contains('arugula') ||
        value.contains('leafy')) {
      return 'Leafy green';
    }

    if (value.contains('onion') ||
        value.contains('garlic') ||
        value.contains('leek') ||
        value.contains('shallot') ||
        value.contains('chive') ||
        value.contains('allium')) {
      return 'Allium';
    }

    if (value.contains('tomato') ||
        value.contains('pepper') ||
        value.contains('capsicum') ||
        value.contains('chilli') ||
        value.contains('chili') ||
        value.contains('eggplant') ||
        value.contains('aubergine') ||
        value.contains('nightshade')) {
      return 'Nightshade';
    }

    if (value.contains('cucumber') ||
        value.contains('zucchini') ||
        value.contains('courgette') ||
        value.contains('pumpkin') ||
        value.contains('squash') ||
        value.contains('melon') ||
        value.contains('watermelon') ||
        value.contains('cucurbit')) {
      return 'Cucurbit';
    }

    if (value.contains('carrot') ||
        value.contains('beet') ||
        value.contains('beetroot') ||
        value.contains('radish') ||
        value.contains('turnip') ||
        value.contains('swede') ||
        value.contains('parsnip') ||
        value.contains('potato') ||
        value.contains('kumara') ||
        value.contains('sweet potato')) {
      return 'Root crop';
    }

    if (value.contains('bean') ||
        value.contains('pea') ||
        value.contains('lentil') ||
        value.contains('legume')) {
      return 'Legume';
    }

    if (profile.category == _PlantInfoCategory.herbs ||
        value.contains('basil') ||
        value.contains('mint') ||
        value.contains('parsley') ||
        value.contains('coriander') ||
        value.contains('cilantro') ||
        value.contains('dill') ||
        value.contains('thyme') ||
        value.contains('rosemary') ||
        value.contains('sage') ||
        value.contains('oregano') ||
        value.contains('lavender')) {
      return 'Herb';
    }

    if (value.contains('strawberry') ||
        value.contains('raspberry') ||
        value.contains('blueberry') ||
        value.contains('blackberry') ||
        value.contains('berry')) {
      return 'Berry';
    }

    if (value.contains('apple') ||
        value.contains('pear') ||
        value.contains('peach') ||
        value.contains('plum') ||
        value.contains('apricot') ||
        value.contains('citrus') ||
        value.contains('lemon') ||
        value.contains('orange') ||
        value.contains('mandarin') ||
        value.contains('lime') ||
        value.contains('fig')) {
      return 'Fruit tree';
    }

    if (profile.category == _PlantInfoCategory.trees ||
        value.contains('tree') ||
        value.contains('oak') ||
        value.contains('maple') ||
        value.contains('birch') ||
        value.contains('palm')) {
      return 'Tree';
    }

    return 'General';
  }

  bool _isPerennial(_PlantProfile profile) {
    final value = '${profile.key} ${profile.name}'.toLowerCase();

    return profile.category == _PlantInfoCategory.trees ||
        value.contains('berry') ||
        value.contains('strawberry') ||
        value.contains('raspberry') ||
        value.contains('blueberry') ||
        value.contains('blackberry') ||
        value.contains('asparagus') ||
        value.contains('artichoke') ||
        value.contains('rosemary') ||
        value.contains('thyme') ||
        value.contains('mint') ||
        value.contains('lavender') ||
        value.contains('sage');
  }

  _PlantInfoCategory _categoryFor(String key, SeedCatalogItem? catalog) {
    final value = '$key ${catalog?.category ?? ''}'.toLowerCase();

    if (_isHerbName(value)) return _PlantInfoCategory.herbs;

    if (value.contains('tree') ||
        value.contains('bush') ||
        value.contains('berry') ||
        value.contains('bonsai') ||
        value.contains('palm') ||
        value.contains('oak') ||
        value.contains('maple') ||
        value.contains('birch') ||
        value.contains('magnolia') ||
        value.contains('apple') ||
        value.contains('apricot') ||
        value.contains('citrus') ||
        value.contains('fig') ||
        value.contains('peach') ||
        value.contains('pear') ||
        value.contains('plum')) {
      return _PlantInfoCategory.trees;
    }

    return _PlantInfoCategory.vegetables;
  }

  static bool _isHerbName(String value) {
    const herbs = {
      'basil',
      'chives',
      'cilantro',
      'coriander',
      'dill',
      'lavender',
      'mint',
      'oregano',
      'parsley',
      'rosemary',
      'sage',
      'thyme',
      'tarragon',
      'echinacea',
      'agastache',
      'catnip',
      'chamomile',
      'fennel',
      'lemon_balm',
      'marjoram',
      'savory',
      'sorrel',
      'yarrow',
    };

    for (final herb in herbs) {
      if (value == herb || value.contains(herb)) return true;
    }

    return false;
  }

  static String _filterLabel(_PlantActionFilter filter) {
    return switch (filter) {
      _PlantActionFilter.all => 'All',
      _PlantActionFilter.recommendedNow => 'Recommended now',
      _PlantActionFilter.sowableNow => 'Sowable',
      _PlantActionFilter.harvestSafe => 'Harvest-safe',
      _PlantActionFilter.risky => 'Risky',
      _PlantActionFilter.tooLate => 'Too late',
      _PlantActionFilter.startTrays => 'Start trays',
      _PlantActionFilter.directSow => 'Direct sow',
      _PlantActionFilter.trayOrDirect => 'Tray/direct',
      _PlantActionFilter.transplantSoon => 'Transplant soon',
      _PlantActionFilter.prepareNextMonth => 'Prepare next',
      _PlantActionFilter.perennials => 'Perennials',
      _PlantActionFilter.fastCrops => 'Fast crops',
      _PlantActionFilter.longSeason => 'Long season',
      _PlantActionFilter.noCalendar => 'No calendar',
    };
  }

  static IconData _filterIcon(_PlantActionFilter filter) {
    return switch (filter) {
      _PlantActionFilter.all => Icons.grid_view,
      _PlantActionFilter.recommendedNow => Icons.recommend_outlined,
      _PlantActionFilter.sowableNow => Icons.eco,
      _PlantActionFilter.harvestSafe => Icons.check_circle_outline,
      _PlantActionFilter.risky => Icons.warning_amber_outlined,
      _PlantActionFilter.tooLate => Icons.block_outlined,
      _PlantActionFilter.startTrays => Icons.inventory_2_outlined,
      _PlantActionFilter.directSow => Icons.grass_outlined,
      _PlantActionFilter.trayOrDirect => Icons.compare_arrows,
      _PlantActionFilter.transplantSoon => Icons.move_down_outlined,
      _PlantActionFilter.prepareNextMonth => Icons.next_plan_outlined,
      _PlantActionFilter.perennials => Icons.park_outlined,
      _PlantActionFilter.fastCrops => Icons.bolt_outlined,
      _PlantActionFilter.longSeason => Icons.timelapse_outlined,
      _PlantActionFilter.noCalendar => Icons.event_busy_outlined,
    };
  }

  static IconData _speciesIcon(String species) {
    return switch (species) {
      'All species' => Icons.grid_view,
      'Brassica' => Icons.eco,
      'Leafy green' => Icons.spa,
      'Allium' => Icons.grass,
      'Nightshade' => Icons.local_florist,
      'Cucurbit' => Icons.park_outlined,
      'Root crop' => Icons.yard_outlined,
      'Legume' => Icons.scatter_plot_outlined,
      'Herb' => Icons.energy_savings_leaf,
      'Berry' => Icons.bubble_chart_outlined,
      'Fruit tree' => Icons.forest_outlined,
      'Tree' => Icons.park,
      _ => Icons.category_outlined,
    };
  }

  static String _categoryLabel(_PlantInfoCategory category) {
    return switch (category) {
      _PlantInfoCategory.all => 'All',
      _PlantInfoCategory.vegetables => 'Vegetables',
      _PlantInfoCategory.herbs => 'Herbs',
      _PlantInfoCategory.trees => 'Trees',
    };
  }

  static String _statusLabel(_HarvestStatus status) {
    return switch (status) {
      _HarvestStatus.safe => 'Harvest-safe',
      _HarvestStatus.risky => 'Risky timing',
      _HarvestStatus.tooLate => 'Too late',
      _HarvestStatus.perennial => 'Long-term',
      _HarvestStatus.unknown => 'No window',
    };
  }

  static Color _statusColor(_HarvestStatus status) {
    return switch (status) {
      _HarvestStatus.safe => GardenTheme.good,
      _HarvestStatus.risky => const Color(0xFFB7791F),
      _HarvestStatus.tooLate => GardenTheme.bad,
      _HarvestStatus.perennial => const Color(0xFF4B6F8C),
      _HarvestStatus.unknown => GardenTheme.muted,
    };
  }

  static String _methodLabel(SowMethod method) {
    return switch (method) {
      SowMethod.tray => 'Start trays',
      SowMethod.direct => 'Direct sow',
      SowMethod.either => 'Tray or direct',
    };
  }

  static String _monthList(List<int> months) {
    if (months.isEmpty) return 'None';

    return months.map(SowCalendar.monthName).join(', ');
  }

  static String _displayNameForKey(String key) {
    return key
        .replaceAll('_', ' ')
        .replaceAll('-', ' ')
        .split(' ')
        .where((part) => part.trim().isNotEmpty)
        .map((part) => part[0].toUpperCase() + part.substring(1))
        .join(' ');
  }

  static String _familyFallback(String key) {
    final value = key.toLowerCase();

    if (_isHerbName(value)) return 'Herb';
    if (value.contains('tree') || value.contains('berry')) return 'Perennial';
    if (value.contains('onion') || value.contains('garlic')) return 'Allium';
    if (value.contains('broccoli') || value.contains('cabbage')) {
      return 'Brassica';
    }
    if (value.contains('tomato') || value.contains('pepper')) {
      return 'Nightshade';
    }

    return 'Plant';
  }

  static String _normalize(String value) {
    return value
        .trim()
        .toLowerCase()
        .replaceAll('&', 'and')
        .replaceAll('-', '_')
        .replaceAll(' ', '_')
        .replaceAll(RegExp(r'[^a-z0-9_]+'), '_')
        .replaceAll(RegExp(r'_+'), '_')
        .replaceAll(RegExp(r'^_|_$'), '');
  }

  static String _normalizeForCompare(String value) {
    return value
        .trim()
        .toLowerCase()
        .replaceAll('&', 'and')
        .replaceAll('-', ' ')
        .replaceAll('_', ' ')
        .replaceAll(RegExp(r'[^a-z0-9]+'), ' ')
        .replaceAll(RegExp(r'\s+'), ' ')
        .trim();
  }

  static int _previousMonth(int month) {
    return month == 1 ? 12 : month - 1;
  }

  static int _nextMonth(int month) {
    return month == 12 ? 1 : month + 1;
  }

  static int _shiftMonth(int month, int offset) {
    var result = month;

    for (var i = 0; i < offset; i++) {
      result = _nextMonth(result);
    }

    return result;
  }

  static int _monthsUntilInclusive(int fromMonth, int toMonth) {
    if (fromMonth <= toMonth) {
      return toMonth - fromMonth + 1;
    }

    return (12 - fromMonth + 1) + toMonth;
  }

  static int _statusRank(_HarvestStatus status) {
    return switch (status) {
      _HarvestStatus.safe => 0,
      _HarvestStatus.perennial => 1,
      _HarvestStatus.risky => 2,
      _HarvestStatus.tooLate => 3,
      _HarvestStatus.unknown => 4,
    };
  }
}

class _PlantInfoCard extends StatelessWidget {
  const _PlantInfoCard({
    required this.profile,
    required this.season,
    required this.groups,
    required this.varietyCount,
    required this.matchedVariety,
    required this.profileData,
    required this.onTap,
  });

  final _PlantProfile profile;
  final _SeasonInfo season;
  final List<PlantTypeGroup> groups;
  final int varietyCount;
  final PlantVariety? matchedVariety;
  final PlantProfileData profileData;
  final VoidCallback onTap;

  @override
  Widget build(BuildContext context) {
    final statusColor = _PlantInfoLibraryViewState._statusColor(season.status);
    final groupTitle = groups.isEmpty ? profile.family : groups.first.title;

    final title = profile.name.toUpperCase();
    final subtitle = varietyCount > 0
        ? '$groupTitle · $varietyCount type${varietyCount == 1 ? '' : 's'}'
        : groupTitle;

    final timingText = season.daysNeeded <= 0
        ? _nextWindowText(season)
        : '${season.daysNeeded}d needed · ${season.daysAvailable}d left';

    final varietyText = matchedVariety == null
        ? 'No subtype profile yet'
        : matchedVariety!.name;

    final spacingText = matchedVariety == null
        ? CropSpacing.spacingLabelForCrop(profile.name)
        : '${matchedVariety!.spacingCm}cm spacing';

    return RepaintBoundary(
      child: Tooltip(
        message: profile.name,
        waitDuration: const Duration(milliseconds: 300),
        child: Material(
          color: Colors.transparent,
          borderRadius: BorderRadius.circular(20),
          clipBehavior: Clip.hardEdge,
          child: InkWell(
            onTap: onTap,
            child: Container(
              decoration: BoxDecoration(
                color: const Color(0xFFFEFCF7),
                borderRadius: BorderRadius.circular(20),
                border: Border.all(
                  color: statusColor.withValues(alpha: 0.40),
                  width: 1.35,
                ),
              ),
              child: Column(
                children: [
                  _StatusBand(
                    color: statusColor,
                    icon: _statusIcon(season.status),
                    label: _PlantInfoLibraryViewState._statusLabel(
                      season.status,
                    ),
                  ),
                  Expanded(
                    child: SingleChildScrollView(
                      physics: const ClampingScrollPhysics(),
                      padding: const EdgeInsets.fromLTRB(13, 11, 13, 11),
                      child: Column(
                        mainAxisSize: MainAxisSize.min,
                        children: [
                          Container(
                            width: 76,
                            height: 76,
                            padding: const EdgeInsets.all(9),
                            decoration: BoxDecoration(
                              color: const Color(0xFFF5F0E8),
                              shape: BoxShape.circle,
                              border: Border.all(color: GardenTheme.border),
                            ),
                            child: Center(
                              child: GeneratedPlantIcon(
                                cropName: profile.key,
                                size: 56,
                              ),
                            ),
                          ),
                          const SizedBox(height: 9),
                          Text(
                            title,
                            textAlign: TextAlign.center,
                            maxLines: 2,
                            overflow: TextOverflow.ellipsis,
                            style: const TextStyle(
                              color: GardenTheme.ink,
                              fontSize: 12,
                              fontWeight: FontWeight.w900,
                              letterSpacing: 0.7,
                              height: 1.13,
                            ),
                          ),
                          const SizedBox(height: 4),
                          Text(
                            subtitle,
                            textAlign: TextAlign.center,
                            maxLines: 1,
                            overflow: TextOverflow.ellipsis,
                            style: const TextStyle(
                              color: GardenTheme.muted,
                              fontSize: 10,
                              fontWeight: FontWeight.w800,
                            ),
                          ),
                          const SizedBox(height: 10),
                          _SafeSummaryBox(
                            varietyText: varietyText,
                            spacingText: spacingText,
                            timingText: timingText,
                          ),
                          const SizedBox(height: 10),
                          _PlanningChips(data: profileData),
                          const SizedBox(height: 10),
                          Container(
                            height: 28,
                            width: double.infinity,
                            alignment: Alignment.center,
                            decoration: BoxDecoration(
                              color: GardenTheme.ink,
                              borderRadius: BorderRadius.circular(999),
                            ),
                            child: const Text(
                              'Tap for full details',
                              maxLines: 1,
                              overflow: TextOverflow.ellipsis,
                              style: TextStyle(
                                color: GardenTheme.cream,
                                fontSize: 10.5,
                                fontWeight: FontWeight.w900,
                              ),
                            ),
                          ),
                        ],
                      ),
                    ),
                  ),
                ],
              ),
            ),
          ),
        ),
      ),
    );
  }

  static IconData _statusIcon(_HarvestStatus status) {
    return switch (status) {
      _HarvestStatus.safe => Icons.check_circle_outline,
      _HarvestStatus.risky => Icons.warning_amber_outlined,
      _HarvestStatus.tooLate => Icons.block_outlined,
      _HarvestStatus.perennial => Icons.park_outlined,
      _HarvestStatus.unknown => Icons.info_outline,
    };
  }

  static String _nextWindowText(_SeasonInfo info) {
    if (info.nextGoodMonth != null) {
      return 'Best ${SowCalendar.monthName(info.nextGoodMonth!)}';
    }

    if (info.nextAnyMonth != null) {
      return 'Next ${SowCalendar.monthName(info.nextAnyMonth!)}';
    }

    return 'No window';
  }
}

class _StatusBand extends StatelessWidget {
  const _StatusBand({
    required this.color,
    required this.icon,
    required this.label,
  });

  final Color color;
  final IconData icon;
  final String label;

  @override
  Widget build(BuildContext context) {
    return Container(
      height: 36,
      width: double.infinity,
      padding: const EdgeInsets.symmetric(horizontal: 12),
      decoration: BoxDecoration(
        color: color.withValues(alpha: 0.10),
        border: Border(
          bottom: BorderSide(color: color.withValues(alpha: 0.18)),
        ),
      ),
      child: Row(
        children: [
          Icon(icon, color: color, size: 16),
          const SizedBox(width: 6),
          Expanded(
            child: Text(
              label,
              maxLines: 1,
              overflow: TextOverflow.ellipsis,
              style: TextStyle(
                color: color,
                fontSize: 10.8,
                fontWeight: FontWeight.w900,
              ),
            ),
          ),
        ],
      ),
    );
  }
}

class _SafeSummaryBox extends StatelessWidget {
  const _SafeSummaryBox({
    required this.varietyText,
    required this.spacingText,
    required this.timingText,
  });

  final String varietyText;
  final String spacingText;
  final String timingText;

  @override
  Widget build(BuildContext context) {
    return Container(
      width: double.infinity,
      padding: const EdgeInsets.fromLTRB(10, 9, 10, 9),
      decoration: BoxDecoration(
        color: const Color(0xFFF5F0E8),
        borderRadius: BorderRadius.circular(14),
        border: Border.all(color: GardenTheme.border),
      ),
      child: Column(
        mainAxisSize: MainAxisSize.min,
        children: [
          Text(
            varietyText,
            maxLines: 1,
            overflow: TextOverflow.ellipsis,
            textAlign: TextAlign.center,
            style: const TextStyle(
              color: GardenTheme.ink,
              fontSize: 10.8,
              fontWeight: FontWeight.w900,
            ),
          ),
          const SizedBox(height: 7),
          Wrap(
            alignment: WrapAlignment.center,
            spacing: 6,
            runSpacing: 6,
            children: [
              _TinyInfoPill(icon: Icons.straighten, label: spacingText),
              _TinyInfoPill(icon: Icons.schedule, label: timingText),
            ],
          ),
        ],
      ),
    );
  }
}

class _PlanningChips extends StatelessWidget {
