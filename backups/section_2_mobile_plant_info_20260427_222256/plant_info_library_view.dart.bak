        _TinyInfoPill(
          icon: Icons.dashboard_customize_outlined,
          label: data.recommendedLayout,
        ),
        _TinyInfoPill(icon: Icons.wb_sunny_outlined, label: data.sun),
        _TinyInfoPill(icon: Icons.water_drop_outlined, label: data.water),
        _TinyInfoPill(icon: Icons.rotate_right, label: data.rotationFamily),
      ],
    );
  }
}

class _TinyInfoPill extends StatelessWidget {
