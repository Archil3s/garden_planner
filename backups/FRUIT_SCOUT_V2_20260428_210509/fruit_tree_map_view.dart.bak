    'Plum': 'Stone',
    'Cherry': 'Stone',
    'Damson': 'Stone',
    'Fig': 'Mediterranean',
    'Mulberry': 'Mediterranean',
    'Persimmon': 'Mediterranean',
    'Pomegranate': 'Mediterranean',
    'Olive': 'Mediterranean',
    'Lemon': 'Citrus',
