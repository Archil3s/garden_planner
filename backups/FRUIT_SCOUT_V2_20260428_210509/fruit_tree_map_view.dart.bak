    'Banana': 'Subtropical',
    'Mango': 'Subtropical',
    'Papaya': 'Subtropical',
    'Pawpaw': 'Subtropical',
    'Lychee': 'Subtropical',
    'Cherimoya': 'Subtropical',
    'Almond': 'Nut',
