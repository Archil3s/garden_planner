import 'dart:math' as math;

import 'package:flutter/material.dart';

import 'package:garden_planner/core/models/bed.dart';
import 'package:garden_planner/core/models/crop_spacing.dart';
import 'package:garden_planner/core/plant_icons/generated_plant_icon.dart';
import 'package:garden_planner/features/planner/controller/garden_controller.dart';
import 'package:garden_planner/features/planner/services/planting_selection_bridge.dart';
import 'package:garden_planner/features/planner/services/project_storage_service.dart';
import 'package:garden_planner/features/planner/ui/garden_screen.dart';
import 'package:garden_planner/features/planner/ui/widgets/plant_info_library_view.dart';

class MobileSectionShell extends StatefulWidget {
  const MobileSectionShell({super.key});

  @override
  State<MobileSectionShell> createState() => _MobileSectionShellState();
}

class _MobileSectionShellState extends State<MobileSectionShell> {
  final GardenController controller = GardenController();
  final ProjectStorageService storage = ProjectStorageService();

  int selectedIndex = 0;
  bool saving = false;
  bool freehandMode = true;
  bool showGrid = true;

  String? selectedPlantName;
  String statusMessage = 'Demo garden map ready.';

  Offset? _lastDrawPoint;
  DateTime? _lastDrawAt;

  @override
  void initState() {
    super.initState();
    controller.addListener(_controllerChanged);
    Future.microtask(_loadSavedProject);
  }

  @override
  void dispose() {
    controller.removeListener(_controllerChanged);
    controller.dispose();
    super.dispose();
  }

  void _controllerChanged() {
    if (!mounted) return;
    setState(() {});
  }

  Future<void> _loadSavedProject() async {
    try {
      final saved = await storage.loadProject().timeout(
        const Duration(seconds: 3),
        onTimeout: () => null,
      );

      if (saved != null) {
        controller.project = saved;
        statusMessage = 'Saved garden project loaded.';
      } else {
        statusMessage = 'Demo garden project loaded.';
      }

      if (controller.selectedBed == null && controller.beds.isNotEmpty) {
        controller.selectBed(controller.beds.first.id);
      }
    } catch (_) {
      statusMessage = 'Saved project could not load. Demo project is active.';

      if (controller.selectedBed == null && controller.beds.isNotEmpty) {
        controller.selectBed(controller.beds.first.id);
      }
    }

    if (mounted) setState(() {});
  }

  Future<void> _saveProject() async {
    if (saving) return;

    setState(() {
      saving = true;
    });

    try {
      await storage.saveProject(controller.project);

      if (!mounted) return;

      ScaffoldMessenger.of(
        context,
      ).showSnackBar(const SnackBar(content: Text('Garden project saved.')));
    } catch (error) {
      if (!mounted) return;

      ScaffoldMessenger.of(
        context,
      ).showSnackBar(SnackBar(content: Text('Save failed: $error')));
    } finally {
      if (mounted) {
        setState(() {
          saving = false;
        });
      }
    }
  }

  void _setTab(int index) {
    setState(() {
      selectedIndex = index;
    });
  }

  void _choosePlant(String cropName) {
    final cleanName = cropName.trim();
    if (cleanName.isEmpty) return;

    PlantingSelectionBridge.selectPlant(cleanName);

    setState(() {
      selectedPlantName = cleanName;
      selectedIndex = 2;
      freehandMode = true;
    });

    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(
        content: Text(
          '$cleanName selected. Tap or drag inside the selected bed.',
        ),
        duration: const Duration(seconds: 2),
      ),
    );
  }

  Bed? get selectedBed {
    final active = controller.selectedBed;
    if (active != null) return active;
    if (controller.beds.isEmpty) return null;
    return controller.beds.first;
  }

  int get plantedBedCount {
    return controller.beds.where((bed) {
      return bed.crops.isNotEmpty ||
          bed.cropPlacements.isNotEmpty ||
          bed.cropBlocks.isNotEmpty;
    }).length;
  }

  int get issueCount {
    return controller.beds.fold<int>(
      0,
      (total, bed) => total + bed.issues.length,
    );
  }

  String _bedTitle(Bed bed) {
    return bed.name.trim().isEmpty ? 'Bed ${bed.number}' : bed.name.trim();
  }

  void _selectBed(Bed bed) {
    controller.selectBed(bed.id);

    setState(() {
      _lastDrawPoint = null;
      _lastDrawAt = null;
    });
  }

  void _drawAt({
    required Bed bed,
    required Offset localPosition,
    required Size canvasSize,
    bool force = false,
  }) {
    final plant = selectedPlantName?.trim();

    if (plant == null || plant.isEmpty) {
      ScaffoldMessenger.of(
        context,
      ).showSnackBar(const SnackBar(content: Text('Pick a plant first.')));

      setState(() {
        selectedIndex = 1;
      });

      return;
    }

    if (canvasSize.width <= 0 || canvasSize.height <= 0) return;

    final bedWidth = math.max(0.1, bed.width);
    final bedHeight = math.max(0.1, bed.height);

    final spacing = CropSpacing.spacingMetersForCrop(
      plant,
    ).clamp(0.10, math.max(0.10, math.min(bedWidth, bedHeight))).toDouble();

    final pixelsPerMeter = math.min(
      canvasSize.width / bedWidth,
      canvasSize.height / bedHeight,
    );

    final now = DateTime.now();

    if (!force) {
      final lastAt = _lastDrawAt;
      final lastPoint = _lastDrawPoint;
      final minPixelMove = math.max(10.0, spacing * pixelsPerMeter * 0.72);

      if (lastAt != null &&
          now.difference(lastAt).inMilliseconds < 80 &&
          lastPoint != null &&
          (localPosition - lastPoint).distance < minPixelMove) {
        return;
      }
    }

    final rawX = (localPosition.dx / canvasSize.width * bedWidth)
        .clamp(0.0, bedWidth)
        .toDouble();

    final rawY = (localPosition.dy / canvasSize.height * bedHeight)
        .clamp(0.0, bedHeight)
        .toDouble();

    final snappedX = ((rawX / spacing).round() * spacing)
        .clamp(0.0, bedWidth)
        .toDouble();

    final snappedY = ((rawY / spacing).round() * spacing)
        .clamp(0.0, bedHeight)
        .toDouble();

    final minimumDistance = math.max(0.08, spacing * 0.78);

    final tooClose = bed.cropBlocks.any((block) {
      if (block.cropName.trim().toLowerCase() != plant.toLowerCase()) {
        return false;
      }

      final dx = block.x - snappedX;
      final dy = block.y - snappedY;
      final distance = math.sqrt(dx * dx + dy * dy);

      return distance < minimumDistance;
    });

    if (tooClose) return;

    controller.selectBed(bed.id);
    controller.addCropBlockToBedAt(
      bedId: bed.id,
      cropName: plant,
      x: snappedX,
      y: snappedY,
    );

    _lastDrawAt = now;
    _lastDrawPoint = localPosition;
  }

  void _addPlantToSelectedBed() {
    final bed = selectedBed;
    final plant = selectedPlantName?.trim();

    if (bed == null) {
      ScaffoldMessenger.of(
        context,
      ).showSnackBar(const SnackBar(content: Text('No bed available.')));
      return;
    }

    if (plant == null || plant.isEmpty) {
      setState(() {
        selectedIndex = 1;
      });

      ScaffoldMessenger.of(
        context,
      ).showSnackBar(const SnackBar(content: Text('Pick a plant first.')));
      return;
    }

    controller.selectBed(bed.id);
    controller.addCropBlockToSelectedBed(plant);

    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(content: Text('$plant added to ${_bedTitle(bed)}.')),
    );
  }

  void _openBedSheet(Bed bed) {
    _selectBed(bed);

    showModalBottomSheet<void>(
      context: context,
      isScrollControlled: true,
      showDragHandle: true,
      backgroundColor: const Color(0xFFFFFBF4),
      builder: (context) {
        return DraggableScrollableSheet(
          expand: false,
          initialChildSize: 0.78,
          minChildSize: 0.40,
          maxChildSize: 0.96,
          builder: (context, scrollController) {
            return ListView(
              controller: scrollController,
              padding: const EdgeInsets.fromLTRB(16, 4, 16, 28),
              children: [
                Text(
                  _bedTitle(bed),
                  style: Theme.of(context).textTheme.headlineSmall?.copyWith(
                    fontWeight: FontWeight.w900,
                  ),
                ),
                const SizedBox(height: 6),
                Text(
                  '${bed.zone} • ${bed.width.toStringAsFixed(1)}m × ${bed.height.toStringAsFixed(1)}m',
                ),
                const SizedBox(height: 16),
                _BedDetailTile(
                  icon: Icons.health_and_safety_outlined,
                  title: 'Health',
                  value: '${(bed.healthPercent * 100).round()}%',
                ),
                _BedDetailTile(
                  icon: Icons.eco_outlined,
                  title: 'Crops',
                  value: bed.crops.isEmpty
                      ? 'No crops yet'
                      : bed.crops.join(', '),
                ),
                _BedDetailTile(
                  icon: Icons.circle_outlined,
                  title: 'Mobile plant icons',
                  value:
                      '${bed.cropBlocks.length + bed.cropPlacements.length} icons',
                ),
                _BedDetailTile(
                  icon: Icons.warning_amber_outlined,
                  title: 'Issues',
                  value: bed.issues.isEmpty
                      ? 'No issue records'
                      : '${bed.issues.length} issue records',
                ),
                const SizedBox(height: 16),
                FilledButton.icon(
                  onPressed: () {
                    Navigator.of(context).pop();
                    _addPlantToSelectedBed();
                  },
                  icon: const Icon(Icons.add_location_alt_outlined),
                  label: Text(
                    selectedPlantName == null
                        ? 'Pick a plant first'
                        : 'Add $selectedPlantName',
                  ),
                ),
                const SizedBox(height: 10),
                OutlinedButton.icon(
                  onPressed: () {
                    Navigator.of(context).pop();
                    setState(() {
                      freehandMode = true;
                    });
                  },
                  icon: const Icon(Icons.draw_outlined),
                  label: const Text('Freehand draw mode'),
                ),
              ],
            );
          },
        );
      },
    );
  }

  String get title {
    return switch (selectedIndex) {
      0 => 'Planner',
      1 => 'Plants',
      2 => 'Map',
      3 => 'Port',
      _ => 'Garden Planner',
    };
  }

  @override
  Widget build(BuildContext context) {
    final pages = <Widget>[
      const GardenScreen(),
      PlantInfoLibraryView(onPlantChosen: _choosePlant),
      _buildMobileMapPage(context),
      _PortStatusPage(
        statusMessage: statusMessage,
        selectedPlantName: selectedPlantName,
        bedCount: controller.beds.length,
        plantedBedCount: plantedBedCount,
        issueCount: issueCount,
        onOpenPlanner: () => _setTab(0),
        onOpenPlants: () => _setTab(1),
        onOpenMap: () => _setTab(2),
      ),
    ];

    return Scaffold(
      backgroundColor: const Color(0xFFF7F2EA),
      appBar: selectedIndex == 0
          ? null
          : AppBar(
              title: Text(title),
              centerTitle: false,
              backgroundColor: const Color(0xFFF7F2EA),
              surfaceTintColor: Colors.transparent,
              actions: [
                if (selectedPlantName != null)
                  Padding(
                    padding: const EdgeInsets.only(right: 6),
                    child: Center(
                      child: Chip(
                        visualDensity: VisualDensity.compact,
                        label: Text(
                          selectedPlantName!,
                          overflow: TextOverflow.ellipsis,
                        ),
                      ),
                    ),
                  ),
                if (selectedIndex == 2)
                  IconButton(
                    tooltip: 'Save',
                    onPressed: saving ? null : _saveProject,
                    icon: saving
                        ? const SizedBox(
                            width: 18,
                            height: 18,
                            child: CircularProgressIndicator(strokeWidth: 2),
                          )
                        : const Icon(Icons.save_outlined),
                  ),
              ],
            ),
      body: SafeArea(
        top: selectedIndex != 0,
        child: IndexedStack(index: selectedIndex, children: pages),
      ),
      bottomNavigationBar: NavigationBar(
        selectedIndex: selectedIndex,
        onDestinationSelected: _setTab,
        destinations: const [
          NavigationDestination(
            icon: Icon(Icons.yard_outlined),
            selectedIcon: Icon(Icons.yard),
            label: 'Planner',
          ),
          NavigationDestination(
            icon: Icon(Icons.eco_outlined),
            selectedIcon: Icon(Icons.eco),
            label: 'Plants',
          ),
          NavigationDestination(
            icon: Icon(Icons.map_outlined),
            selectedIcon: Icon(Icons.map),
            label: 'Map',
          ),
          NavigationDestination(
            icon: Icon(Icons.phone_android_outlined),
            selectedIcon: Icon(Icons.phone_android),
            label: 'Port',
          ),
        ],
      ),
    );
  }

  Widget _buildMobileMapPage(BuildContext context) {
    final bed = selectedBed;

    if (controller.beds.isEmpty || bed == null) {
      return const Center(child: Text('No beds available.'));
    }

    return CustomScrollView(
      slivers: [
        SliverPadding(
          padding: const EdgeInsets.fromLTRB(12, 8, 12, 6),
          sliver: SliverToBoxAdapter(
            child: _MapHeader(
              bedName: _bedTitle(bed),
              selectedPlantName: selectedPlantName,
              bedCount: controller.beds.length,
              plantedBedCount: plantedBedCount,
              freehandMode: freehandMode,
              showGrid: showGrid,
              onPickPlant: () => _setTab(1),
              onAddPlant: _addPlantToSelectedBed,
              onFreehandChanged: (value) {
                setState(() {
                  freehandMode = value;
                });
              },
              onGridChanged: (value) {
                setState(() {
                  showGrid = value;
                });
              },
            ),
          ),
        ),
        SliverToBoxAdapter(
          child: SizedBox(
            height: 52,
            child: ListView.separated(
              scrollDirection: Axis.horizontal,
              padding: const EdgeInsets.fromLTRB(12, 4, 12, 8),
              itemCount: controller.beds.length,
              separatorBuilder: (context, index) => const SizedBox(width: 8),
              itemBuilder: (context, index) {
                final item = controller.beds[index];
                final selected = item.id == bed.id;

                return ChoiceChip(
                  selected: selected,
                  label: Text(_bedTitle(item)),
                  avatar: selected
                      ? const Icon(Icons.check_circle, size: 18)
                      : const Icon(Icons.view_week_outlined, size: 18),
                  onSelected: (_) => _selectBed(item),
                );
              },
            ),
          ),
        ),
        SliverPadding(
          padding: const EdgeInsets.fromLTRB(12, 4, 12, 12),
          sliver: SliverToBoxAdapter(
            child: _MobileBedCanvas(
              bed: bed,
              selectedPlantName: selectedPlantName,
              freehandMode: freehandMode,
              showGrid: showGrid,
              onDraw: (position, size, force) {
                _drawAt(
                  bed: bed,
                  localPosition: position,
                  canvasSize: size,
                  force: force,
                );
              },
              onOpenDetails: () => _openBedSheet(bed),
            ),
          ),
        ),
        SliverPadding(
          padding: const EdgeInsets.fromLTRB(12, 0, 12, 24),
          sliver: SliverList.list(
            children: [
              _BedSummaryCard(
                bed: bed,
                title: _bedTitle(bed),
                onOpen: () => _openBedSheet(bed),
                onAdd: _addPlantToSelectedBed,
              ),
              const SizedBox(height: 10),
              _InstructionCard(
                freehandMode: freehandMode,
                selectedPlantName: selectedPlantName,
              ),
            ],
          ),
        ),
      ],
    );
  }
}

class _MapHeader extends StatelessWidget {
  const _MapHeader({
    required this.bedName,
    required this.selectedPlantName,
    required this.bedCount,
    required this.plantedBedCount,
    required this.freehandMode,
    required this.showGrid,
    required this.onPickPlant,
    required this.onAddPlant,
    required this.onFreehandChanged,
    required this.onGridChanged,
  });

  final String bedName;
  final String? selectedPlantName;
  final int bedCount;
  final int plantedBedCount;
  final bool freehandMode;
  final bool showGrid;
  final VoidCallback onPickPlant;
  final VoidCallback onAddPlant;
  final ValueChanged<bool> onFreehandChanged;
  final ValueChanged<bool> onGridChanged;

  @override
  Widget build(BuildContext context) {
    return Card(
      elevation: 0,
      color: Colors.white,
      shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(22)),
      child: Padding(
        padding: const EdgeInsets.all(14),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            Row(
              children: [
                const Icon(Icons.map_outlined),
                const SizedBox(width: 10),
                Expanded(
                  child: Text(
                    bedName,
                    maxLines: 1,
                    overflow: TextOverflow.ellipsis,
                    style: Theme.of(context).textTheme.titleLarge?.copyWith(
                      fontWeight: FontWeight.w900,
                    ),
                  ),
                ),
              ],
            ),
            const SizedBox(height: 6),
            Text(
              '$plantedBedCount/$bedCount beds planted',
              maxLines: 1,
              overflow: TextOverflow.ellipsis,
            ),
            const SizedBox(height: 12),
            Wrap(
              spacing: 8,
              runSpacing: 8,
              children: [
                FilledButton.icon(
                  onPressed: onPickPlant,
                  icon: const Icon(Icons.eco_outlined),
                  label: Text(selectedPlantName ?? 'Pick plant'),
                ),
                OutlinedButton.icon(
                  onPressed: onAddPlant,
                  icon: const Icon(Icons.add_location_alt_outlined),
                  label: const Text('Add'),
                ),
                FilterChip(
                  selected: freehandMode,
                  avatar: const Icon(Icons.draw_outlined, size: 18),
                  label: const Text('Freehand'),
                  onSelected: onFreehandChanged,
                ),
                FilterChip(
                  selected: showGrid,
                  avatar: const Icon(Icons.grid_on, size: 18),
                  label: const Text('Grid'),
                  onSelected: onGridChanged,
                ),
              ],
            ),
          ],
        ),
      ),
    );
  }
}

class _MobileBedCanvas extends StatelessWidget {
  const _MobileBedCanvas({
    required this.bed,
    required this.selectedPlantName,
    required this.freehandMode,
    required this.showGrid,
    required this.onDraw,
    required this.onOpenDetails,
  });

  final Bed bed;
  final String? selectedPlantName;
  final bool freehandMode;
  final bool showGrid;
  final void Function(Offset localPosition, Size canvasSize, bool force) onDraw;
  final VoidCallback onOpenDetails;

  @override
  Widget build(BuildContext context) {
    final aspect = bed.width <= 0 || bed.height <= 0
        ? 1.20
        : (bed.width / bed.height).clamp(0.78, 1.45);

    return Card(
      elevation: 0,
      color: Colors.white,
      clipBehavior: Clip.antiAlias,
      shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(24)),
      child: Padding(
        padding: const EdgeInsets.all(10),
        child: LayoutBuilder(
          builder: (context, constraints) {
            final canvasWidth = constraints.maxWidth;
            final canvasHeight = (canvasWidth / aspect).clamp(300.0, 440.0);
            final canvasSize = Size(canvasWidth, canvasHeight);

            return Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Row(
                  children: [
                    const Icon(Icons.view_week_outlined, size: 20),
                    const SizedBox(width: 8),
                    Expanded(
                      child: Text(
                        'Selected bed surface',
                        maxLines: 1,
                        overflow: TextOverflow.ellipsis,
                        style: Theme.of(context).textTheme.titleMedium
                            ?.copyWith(fontWeight: FontWeight.w900),
                      ),
                    ),
                    IconButton.outlined(
                      onPressed: onOpenDetails,
                      icon: const Icon(Icons.info_outline),
                      tooltip: 'Bed details',
                    ),
                  ],
                ),
                const SizedBox(height: 8),
                GestureDetector(
                  behavior: HitTestBehavior.opaque,
                  onTapDown: freehandMode
                      ? (details) =>
                            onDraw(details.localPosition, canvasSize, true)
                      : null,
                  onPanStart: freehandMode
                      ? (details) =>
                            onDraw(details.localPosition, canvasSize, true)
                      : null,
                  onPanUpdate: freehandMode
                      ? (details) =>
                            onDraw(details.localPosition, canvasSize, false)
                      : null,
                  child: SizedBox(
                    width: canvasWidth,
                    height: canvasHeight,
                    child: ClipRRect(
                      borderRadius: BorderRadius.circular(20),
                      child: Stack(
                        children: [
                          Positioned.fill(
                            child: CustomPaint(
                              painter: _BedSurfacePainter(showGrid: showGrid),
                            ),
                          ),
                          Positioned.fill(
                            child: _BedCropLayer(
                              bed: bed,
                              canvasSize: canvasSize,
                            ),
                          ),
                        ],
                      ),
                    ),
                  ),
                ),
              ],
            );
          },
        ),
      ),
    );
  }
}

class _BedCropLayer extends StatelessWidget {
  const _BedCropLayer({required this.bed, required this.canvasSize});

  final Bed bed;
  final Size canvasSize;

  @override
  Widget build(BuildContext context) {
    final widgets = <Widget>[];

    for (final block in bed.cropBlocks) {
      widgets.add(
        _positionedMarker(
          cropName: block.cropName,
          xMeters: block.x,
          yMeters: block.y,
        ),
      );
    }

    for (final placement in bed.cropPlacements) {
      widgets.add(
        _positionedMarker(
          cropName: placement.cropName,
          xMeters: placement.x,
          yMeters: placement.y,
        ),
      );
    }

    if (widgets.isEmpty) {
      widgets.add(
        const Positioned.fill(
          child: Center(
            child: Padding(
              padding: EdgeInsets.all(24),
              child: Text(
                'Pick a plant, then tap or drag inside this bed',
                textAlign: TextAlign.center,
                style: TextStyle(fontWeight: FontWeight.w800, fontSize: 13),
              ),
            ),
          ),
        ),
      );
    }

    return Stack(children: widgets);
  }

  Widget _positionedMarker({
    required String cropName,
    required double xMeters,
    required double yMeters,
  }) {
    final bedWidth = math.max(0.1, bed.width);
    final bedHeight = math.max(0.1, bed.height);

    final pixelsPerMeter = math.min(
      canvasSize.width / bedWidth,
      canvasSize.height / bedHeight,
    );

    final spacingMeters = CropSpacing.spacingMetersForCrop(
      cropName,
    ).clamp(0.10, math.max(0.10, math.min(bedWidth, bedHeight))).toDouble();

    final markerSize = (spacingMeters * pixelsPerMeter * 0.24)
        .clamp(9.0, 18.0)
        .toDouble();

    final centerX = (xMeters / bedWidth).clamp(0.0, 1.0) * canvasSize.width;
    final centerY = (yMeters / bedHeight).clamp(0.0, 1.0) * canvasSize.height;

    final left = (centerX - markerSize / 2)
        .clamp(0.0, math.max(0.0, canvasSize.width - markerSize))
        .toDouble();

    final top = (centerY - markerSize / 2)
        .clamp(0.0, math.max(0.0, canvasSize.height - markerSize))
        .toDouble();

    return Positioned(
      left: left,
      top: top,
      width: markerSize,
      height: markerSize,
      child: _MobilePlantMarker(
        cropName: cropName,
        spacingMeters: spacingMeters,
      ),
    );
  }
}

class _MobilePlantMarker extends StatelessWidget {
  const _MobilePlantMarker({
    required this.cropName,
    required this.spacingMeters,
  });

  final String cropName;
  final double spacingMeters;

  @override
  Widget build(BuildContext context) {
    return Tooltip(
      message: '$cropName • ${spacingMeters.toStringAsFixed(2)}m spacing',
      child: Container(
        alignment: Alignment.center,
        decoration: BoxDecoration(
          color: Colors.white.withValues(alpha: 0.95),
          shape: BoxShape.circle,
          border: Border.all(color: const Color(0xFF2E7D32), width: 0.75),
          boxShadow: [
            BoxShadow(
              color: Colors.black.withValues(alpha: 0.05),
              blurRadius: 1.5,
              offset: const Offset(0, 0.8),
            ),
          ],
        ),
        child: LayoutBuilder(
          builder: (context, constraints) {
            final size = math.min(constraints.maxWidth, constraints.maxHeight);
            final iconSize = (size * 0.58).clamp(6.0, 11.0).toDouble();

            return GeneratedPlantIcon(cropName: cropName, size: iconSize);
          },
        ),
      ),
    );
  }
}

class _BedSurfacePainter extends CustomPainter {
  const _BedSurfacePainter({required this.showGrid});

  final bool showGrid;

  @override
  void paint(Canvas canvas, Size size) {
    final soil = Paint()..color = const Color(0xFFE9D2A8);
    final border = Paint()
      ..color = const Color(0xFF7A5A36)
      ..style = PaintingStyle.stroke
      ..strokeWidth = 4;

    final rect = Offset.zero & size;
    final rrect = RRect.fromRectAndRadius(rect, const Radius.circular(20));

    canvas.drawRRect(rrect, soil);
    canvas.drawRRect(rrect.deflate(2), border);

    if (!showGrid) return;

    final grid = Paint()
      ..color = const Color(0xFF7A5A36).withValues(alpha: 0.12)
      ..strokeWidth = 1;

    const step = 32.0;

    for (double x = step; x < size.width; x += step) {
      canvas.drawLine(Offset(x, 0), Offset(x, size.height), grid);
    }

    for (double y = step; y < size.height; y += step) {
      canvas.drawLine(Offset(0, y), Offset(size.width, y), grid);
    }
  }

  @override
  bool shouldRepaint(covariant _BedSurfacePainter oldDelegate) {
    return oldDelegate.showGrid != showGrid;
  }
}

class _BedSummaryCard extends StatelessWidget {
  const _BedSummaryCard({
    required this.bed,
    required this.title,
    required this.onOpen,
    required this.onAdd,
  });

  final Bed bed;
  final String title;
  final VoidCallback onOpen;
  final VoidCallback onAdd;

  @override
  Widget build(BuildContext context) {
    final cropText = bed.crops.isEmpty ? 'No crops yet' : bed.crops.join(', ');

    return Card(
      elevation: 0,
      color: Colors.white,
      shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(22)),
      child: Padding(
        padding: const EdgeInsets.all(14),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            Text(title, style: const TextStyle(fontWeight: FontWeight.w900)),
            const SizedBox(height: 6),
            Text(cropText, maxLines: 3, overflow: TextOverflow.ellipsis),
            const SizedBox(height: 12),
            Wrap(
              spacing: 8,
              runSpacing: 8,
              children: [
                _MiniChip(label: '${bed.cropBlocks.length} icons'),
                _MiniChip(label: '${bed.cropPlacements.length} placements'),
                _MiniChip(label: '${bed.issues.length} issues'),
                _MiniChip(
                  label: '${(bed.healthPercent * 100).round()}% health',
                ),
              ],
            ),
            const SizedBox(height: 12),
            Row(
              children: [
                Expanded(
                  child: FilledButton.tonal(
                    onPressed: onAdd,
                    child: const Text('Add selected plant'),
                  ),
                ),
                const SizedBox(width: 8),
                IconButton.outlined(
                  onPressed: onOpen,
                  icon: const Icon(Icons.info_outline),
                ),
              ],
            ),
          ],
        ),
      ),
    );
  }
}

class _InstructionCard extends StatelessWidget {
  const _InstructionCard({
    required this.freehandMode,
    required this.selectedPlantName,
  });

  final bool freehandMode;
  final String? selectedPlantName;

  @override
  Widget build(BuildContext context) {
    final text = selectedPlantName == null
        ? 'Pick a plant first. The map places small circular icons based on crop spacing.'
        : freehandMode
        ? 'Freehand is on. Tap or drag to place small spacing-aware plant icons.'
        : 'Freehand is off. Turn it on to draw plants inside the bed.';

    return Card(
      elevation: 0,
      color: const Color(0xFFFFF6DF),
      shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(18)),
      child: ListTile(
        leading: const Icon(Icons.info_outline),
        title: const Text(
          'Mobile map controls',
          style: TextStyle(fontWeight: FontWeight.w900),
        ),
        subtitle: Text(text),
      ),
    );
  }
}

class _BedDetailTile extends StatelessWidget {
  const _BedDetailTile({
    required this.icon,
    required this.title,
    required this.value,
  });

  final IconData icon;
  final String title;
  final String value;

  @override
  Widget build(BuildContext context) {
    return Card(
      elevation: 0,
      color: Theme.of(context).colorScheme.surfaceContainerHighest,
      shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(18)),
      child: ListTile(
        leading: Icon(icon),
        title: Text(title, style: const TextStyle(fontWeight: FontWeight.w900)),
        subtitle: Text(value),
      ),
    );
  }
}

class _MiniChip extends StatelessWidget {
  const _MiniChip({required this.label});

  final String label;

  @override
  Widget build(BuildContext context) {
    return Chip(
      visualDensity: VisualDensity.compact,
      label: Text(
        label,
        style: const TextStyle(fontSize: 11, fontWeight: FontWeight.w800),
      ),
    );
  }
}

class _PortStatusPage extends StatelessWidget {
  const _PortStatusPage({
    required this.statusMessage,
    required this.selectedPlantName,
    required this.bedCount,
    required this.plantedBedCount,
    required this.issueCount,
    required this.onOpenPlanner,
    required this.onOpenPlants,
    required this.onOpenMap,
  });

  final String statusMessage;
  final String? selectedPlantName;
  final int bedCount;
  final int plantedBedCount;
  final int issueCount;
  final VoidCallback onOpenPlanner;
  final VoidCallback onOpenPlants;
  final VoidCallback onOpenMap;

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: const Color(0xFFF7F2EA),
      body: SafeArea(
        child: ListView(
          padding: const EdgeInsets.all(16),
          children: [
            Card(
              elevation: 0,
              color: Colors.white,
              shape: RoundedRectangleBorder(
                borderRadius: BorderRadius.circular(24),
              ),
              child: Padding(
                padding: const EdgeInsets.all(18),
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    const Icon(Icons.phone_android_outlined, size: 34),
                    const SizedBox(height: 12),
                    Text(
                      'Mobile port status',
                      style: Theme.of(context).textTheme.headlineSmall
                          ?.copyWith(fontWeight: FontWeight.w900),
                    ),
                    const SizedBox(height: 8),
                    Text(statusMessage),
                    const SizedBox(height: 14),
                    Chip(
                      avatar: const Icon(Icons.eco_outlined, size: 18),
                      label: Text(
                        selectedPlantName == null
                            ? 'No plant selected'
                            : 'Selected: $selectedPlantName',
                      ),
                    ),
                    const SizedBox(height: 8),
                    Text(
                      '$plantedBedCount/$bedCount beds planted • $issueCount issue records',
                    ),
                    const SizedBox(height: 16),
                    Wrap(
                      spacing: 8,
                      runSpacing: 8,
                      children: [
                        FilledButton.icon(
                          onPressed: onOpenMap,
                          icon: const Icon(Icons.map_outlined),
                          label: const Text('Open map'),
                        ),
                        OutlinedButton.icon(
                          onPressed: onOpenPlants,
                          icon: const Icon(Icons.eco_outlined),
                          label: const Text('Pick plant'),
                        ),
                        OutlinedButton.icon(
                          onPressed: onOpenPlanner,
                          icon: const Icon(Icons.yard_outlined),
                          label: const Text('Planner'),
                        ),
                      ],
                    ),
                  ],
                ),
              ),
            ),
          ],
        ),
      ),
    );
  }
}
