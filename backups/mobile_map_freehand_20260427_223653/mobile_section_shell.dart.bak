import 'package:flutter/material.dart';

import 'package:garden_planner/core/models/bed.dart';
import 'package:garden_planner/features/planner/controller/garden_controller.dart';
import 'package:garden_planner/features/planner/services/planting_selection_bridge.dart';
import 'package:garden_planner/features/planner/services/project_storage_service.dart';
import 'package:garden_planner/features/planner/ui/garden_screen.dart';
import 'package:garden_planner/features/planner/ui/widgets/plant_info_library_view.dart';

class MobileSectionShell extends StatefulWidget {
  const MobileSectionShell({super.key});

  @override
  State<MobileSectionShell> createState() => _MobileSectionShellState();
}

class _MobileSectionShellState extends State<MobileSectionShell> {
  final GardenController controller = GardenController();
  final ProjectStorageService storage = ProjectStorageService();

  int selectedIndex = 0;
  bool saving = false;
  String? selectedPlantName;
  String statusMessage = 'Demo garden map ready.';

  @override
  void initState() {
    super.initState();

    controller.addListener(_controllerChanged);

    Future.microtask(_loadSavedProject);
  }

  @override
  void dispose() {
    controller.removeListener(_controllerChanged);
    controller.dispose();
    super.dispose();
  }

  void _controllerChanged() {
    if (!mounted) return;
    setState(() {});
  }

  Future<void> _loadSavedProject() async {
    try {
      final saved = await storage.loadProject().timeout(
        const Duration(seconds: 3),
        onTimeout: () => null,
      );

      if (saved != null) {
        controller.project = saved;
        statusMessage = 'Saved garden project loaded.';
      } else {
        statusMessage = 'Demo garden project loaded.';
      }

      if (controller.selectedBedId == null && controller.beds.isNotEmpty) {
        controller.selectBed(controller.beds.first.id);
      }
    } catch (_) {
      statusMessage = 'Saved project could not load. Demo project is active.';
    }

    if (mounted) {
      setState(() {});
    }
  }

  Future<void> _saveProject() async {
    if (saving) return;

    setState(() {
      saving = true;
    });

    try {
      await storage.saveProject(controller.project);

      if (!mounted) return;

      ScaffoldMessenger.of(
        context,
      ).showSnackBar(const SnackBar(content: Text('Garden project saved.')));
    } catch (error) {
      if (!mounted) return;

      ScaffoldMessenger.of(
        context,
      ).showSnackBar(SnackBar(content: Text('Save failed: $error')));
    } finally {
      if (mounted) {
        setState(() {
          saving = false;
        });
      }
    }
  }

  void _setTab(int index) {
    setState(() {
      selectedIndex = index;
    });
  }

  void _choosePlant(String cropName) {
    final cleanName = cropName.trim();

    if (cleanName.isEmpty) return;

    PlantingSelectionBridge.selectPlant(cleanName);

    setState(() {
      selectedPlantName = cleanName;
      selectedIndex = 2;
    });

    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(
        content: Text('$cleanName selected. Pick a bed to add it.'),
        duration: const Duration(seconds: 2),
      ),
    );
  }

  Bed? get _selectedBed {
    final selected = controller.selectedBed;

    if (selected != null) return selected;
    if (controller.beds.isEmpty) return null;

    return controller.beds.first;
  }

  int get _plantedBedCount {
    return controller.beds.where((bed) {
      return bed.crops.isNotEmpty ||
          bed.cropPlacements.isNotEmpty ||
          bed.cropBlocks.isNotEmpty;
    }).length;
  }

  int get _issueCount {
    return controller.beds.fold<int>(
      0,
      (total, bed) => total + bed.issues.length,
    );
  }

  void _selectBed(Bed bed) {
    controller.selectBed(bed.id);
    setState(() {});
  }

  void _addPlantToBed(Bed bed) {
    final plant = selectedPlantName?.trim();

    if (plant == null || plant.isEmpty) {
      setState(() {
        selectedIndex = 1;
      });

      ScaffoldMessenger.of(
        context,
      ).showSnackBar(const SnackBar(content: Text('Pick a plant first.')));

      return;
    }

    controller.selectBed(bed.id);
    controller.addCropBlockToSelectedBed(plant);

    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(content: Text('$plant added to ${_bedTitle(bed)}.')),
    );
  }

  void _addPlantToSelectedBed() {
    final bed = _selectedBed;

    if (bed == null) {
      ScaffoldMessenger.of(
        context,
      ).showSnackBar(const SnackBar(content: Text('No beds available.')));
      return;
    }

    _addPlantToBed(bed);
  }

  void _openBedSheet(Bed bed) {
    _selectBed(bed);

    showModalBottomSheet<void>(
      context: context,
      isScrollControlled: true,
      showDragHandle: true,
      backgroundColor: const Color(0xFFFFFBF4),
      builder: (context) {
        return DraggableScrollableSheet(
          expand: false,
          initialChildSize: 0.78,
          minChildSize: 0.42,
          maxChildSize: 0.96,
          builder: (context, scrollController) {
            return ListView(
              controller: scrollController,
              padding: const EdgeInsets.fromLTRB(16, 4, 16, 28),
              children: [
                Text(
                  _bedTitle(bed),
                  style: Theme.of(context).textTheme.headlineSmall?.copyWith(
                    fontWeight: FontWeight.w900,
                  ),
                ),
                const SizedBox(height: 6),
                Text(
                  '${bed.zone} • ${bed.width.toStringAsFixed(1)}m × ${bed.height.toStringAsFixed(1)}m',
                ),
                const SizedBox(height: 16),
                _BedDetailTile(
                  icon: Icons.health_and_safety_outlined,
                  title: 'Health',
                  value: '${(bed.healthPercent * 100).round()}%',
                ),
                _BedDetailTile(
                  icon: Icons.eco_outlined,
                  title: 'Crops',
                  value: bed.crops.isEmpty
                      ? 'No crops yet'
                      : bed.crops.join(', '),
                ),
                _BedDetailTile(
                  icon: Icons.grid_view_outlined,
                  title: 'Placed on map',
                  value:
                      '${bed.cropBlocks.length} crop blocks • ${bed.cropPlacements.length} plant icons',
                ),
                _BedDetailTile(
                  icon: Icons.warning_amber_outlined,
                  title: 'Issues',
                  value: bed.issues.isEmpty
                      ? 'No issue records'
                      : '${bed.issues.length} issue records',
                ),
                const SizedBox(height: 16),
                FilledButton.icon(
                  onPressed: selectedPlantName == null
                      ? null
                      : () {
                          Navigator.of(context).pop();
                          _addPlantToBed(bed);
                        },
                  icon: const Icon(Icons.add_location_alt_outlined),
                  label: Text(
                    selectedPlantName == null
                        ? 'Pick a plant first'
                        : 'Add $selectedPlantName to this bed',
                  ),
                ),
                const SizedBox(height: 10),
                OutlinedButton.icon(
                  onPressed: () {
                    Navigator.of(context).pop();
                  },
                  icon: const Icon(Icons.close),
                  label: const Text('Close'),
                ),
              ],
            );
          },
        );
      },
    );
  }

  String _bedTitle(Bed bed) {
    return bed.name.trim().isEmpty ? 'Bed ${bed.number}' : bed.name.trim();
  }

  String get _title {
    return switch (selectedIndex) {
      0 => 'Planner',
      1 => 'Plants',
      2 => 'Map',
      3 => 'Port',
      _ => 'Garden Planner',
    };
  }

  @override
  Widget build(BuildContext context) {
    final pages = <Widget>[
      const GardenScreen(),
      PlantInfoLibraryView(onPlantChosen: _choosePlant),
      _buildMobileMapPage(context),
      _PortStatusPage(
        statusMessage: statusMessage,
        selectedPlantName: selectedPlantName,
        bedCount: controller.beds.length,
        plantedBedCount: _plantedBedCount,
        issueCount: _issueCount,
        onOpenPlanner: () => _setTab(0),
        onOpenPlants: () => _setTab(1),
        onOpenMap: () => _setTab(2),
      ),
    ];

    return Scaffold(
      backgroundColor: const Color(0xFFF7F2EA),
      appBar: selectedIndex == 0
          ? null
          : AppBar(
              title: Text(_title),
              centerTitle: false,
              backgroundColor: const Color(0xFFF7F2EA),
              surfaceTintColor: Colors.transparent,
              actions: [
                if (selectedPlantName != null)
                  Padding(
                    padding: const EdgeInsets.only(right: 6),
                    child: Center(
                      child: Chip(
                        visualDensity: VisualDensity.compact,
                        label: Text(
                          selectedPlantName!,
                          overflow: TextOverflow.ellipsis,
                        ),
                      ),
                    ),
                  ),
                if (selectedIndex == 2)
                  IconButton(
                    tooltip: 'Save',
                    onPressed: saving ? null : _saveProject,
                    icon: saving
                        ? const SizedBox(
                            width: 18,
                            height: 18,
                            child: CircularProgressIndicator(strokeWidth: 2),
                          )
                        : const Icon(Icons.save_outlined),
                  ),
              ],
            ),
      body: SafeArea(
        top: selectedIndex != 0,
        child: IndexedStack(index: selectedIndex, children: pages),
      ),
      bottomNavigationBar: NavigationBar(
        selectedIndex: selectedIndex,
        onDestinationSelected: _setTab,
        destinations: const [
          NavigationDestination(
            icon: Icon(Icons.yard_outlined),
            selectedIcon: Icon(Icons.yard),
            label: 'Planner',
          ),
          NavigationDestination(
            icon: Icon(Icons.eco_outlined),
            selectedIcon: Icon(Icons.eco),
            label: 'Plants',
          ),
          NavigationDestination(
            icon: Icon(Icons.map_outlined),
            selectedIcon: Icon(Icons.map),
            label: 'Map',
          ),
          NavigationDestination(
            icon: Icon(Icons.phone_android_outlined),
            selectedIcon: Icon(Icons.phone_android),
            label: 'Port',
          ),
        ],
      ),
    );
  }

  Widget _buildMobileMapPage(BuildContext context) {
    final selectedBed = _selectedBed;

    return CustomScrollView(
      slivers: [
        SliverPadding(
          padding: const EdgeInsets.fromLTRB(16, 10, 16, 8),
          sliver: SliverToBoxAdapter(
            child: _MapHeroCard(
              selectedPlantName: selectedPlantName,
              selectedBedName: selectedBed == null
                  ? 'No bed selected'
                  : _bedTitle(selectedBed),
              bedCount: controller.beds.length,
              plantedBedCount: _plantedBedCount,
              statusMessage: statusMessage,
              onPickPlant: () => _setTab(1),
              onAddPlant: _addPlantToSelectedBed,
            ),
          ),
        ),
        SliverToBoxAdapter(
          child: SizedBox(
            height: 58,
            child: ListView(
              scrollDirection: Axis.horizontal,
              padding: const EdgeInsets.fromLTRB(16, 6, 16, 8),
              children: [
                ActionChip(
                  avatar: const Icon(Icons.eco_outlined, size: 18),
                  label: Text(selectedPlantName ?? 'Pick plant'),
                  onPressed: () => _setTab(1),
                ),
                const SizedBox(width: 8),
                ActionChip(
                  avatar: const Icon(Icons.add_location_alt_outlined, size: 18),
                  label: const Text('Add to selected'),
                  onPressed: _addPlantToSelectedBed,
                ),
                const SizedBox(width: 8),
                ActionChip(
                  avatar: const Icon(Icons.save_outlined, size: 18),
                  label: const Text('Save'),
                  onPressed: _saveProject,
                ),
              ],
            ),
          ),
        ),
        if (controller.beds.isEmpty)
          const SliverFillRemaining(
            hasScrollBody: false,
            child: Center(child: Text('No beds available.')),
          )
        else
          SliverPadding(
            padding: const EdgeInsets.fromLTRB(16, 8, 16, 24),
            sliver: SliverLayoutBuilder(
              builder: (context, constraints) {
                final width = constraints.crossAxisExtent;

                if (width < 520) {
                  return SliverList.separated(
                    itemCount: controller.beds.length,
                    separatorBuilder: (_, __) => const SizedBox(height: 12),
                    itemBuilder: (context, index) {
                      final bed = controller.beds[index];
                      final selected = bed.id == controller.selectedBedId;

                      return _MobileBedMapCard(
                        bed: bed,
                        selected: selected,
                        onSelect: () => _selectBed(bed),
                        onOpen: () => _openBedSheet(bed),
                        onAdd: () => _addPlantToBed(bed),
                      );
                    },
                  );
                }

                return SliverGrid(
                  delegate: SliverChildBuilderDelegate((context, index) {
                    final bed = controller.beds[index];
                    final selected = bed.id == controller.selectedBedId;

                    return _MobileBedMapCard(
                      bed: bed,
                      selected: selected,
                      onSelect: () => _selectBed(bed),
                      onOpen: () => _openBedSheet(bed),
                      onAdd: () => _addPlantToBed(bed),
                    );
                  }, childCount: controller.beds.length),
                  gridDelegate: const SliverGridDelegateWithFixedCrossAxisCount(
                    crossAxisCount: 2,
                    mainAxisSpacing: 12,
                    crossAxisSpacing: 12,
                    mainAxisExtent: 260,
                  ),
                );
              },
            ),
          ),
      ],
    );
  }
}

class _MapHeroCard extends StatelessWidget {
  const _MapHeroCard({
    required this.selectedPlantName,
    required this.selectedBedName,
    required this.bedCount,
    required this.plantedBedCount,
    required this.statusMessage,
    required this.onPickPlant,
    required this.onAddPlant,
  });

  final String? selectedPlantName;
  final String selectedBedName;
  final int bedCount;
  final int plantedBedCount;
  final String statusMessage;
  final VoidCallback onPickPlant;
  final VoidCallback onAddPlant;

  @override
  Widget build(BuildContext context) {
    return Card(
      elevation: 0,
      color: Colors.white,
      shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(24)),
      child: Padding(
        padding: const EdgeInsets.all(16),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            Row(
              children: [
                const Icon(Icons.map_outlined),
                const SizedBox(width: 10),
                Expanded(
                  child: Text(
                    'Mobile Garden Map',
                    maxLines: 1,
                    overflow: TextOverflow.ellipsis,
                    style: Theme.of(context).textTheme.titleLarge?.copyWith(
                      fontWeight: FontWeight.w900,
                    ),
                  ),
                ),
              ],
            ),
            const SizedBox(height: 8),
            Text(
              '$plantedBedCount/$bedCount beds planted • $selectedBedName',
              maxLines: 2,
              overflow: TextOverflow.ellipsis,
            ),
            const SizedBox(height: 6),
            Text(
              statusMessage,
              maxLines: 2,
              overflow: TextOverflow.ellipsis,
              style: const TextStyle(fontSize: 12),
            ),
            const SizedBox(height: 12),
            Wrap(
              spacing: 8,
              runSpacing: 8,
              children: [
                FilledButton.icon(
                  onPressed: onPickPlant,
                  icon: const Icon(Icons.eco_outlined),
                  label: Text(selectedPlantName ?? 'Pick plant'),
                ),
                OutlinedButton.icon(
                  onPressed: onAddPlant,
                  icon: const Icon(Icons.add_location_alt_outlined),
                  label: const Text('Add to bed'),
                ),
              ],
            ),
          ],
        ),
      ),
    );
  }
}

class _MobileBedMapCard extends StatelessWidget {
  const _MobileBedMapCard({
    required this.bed,
    required this.selected,
    required this.onSelect,
    required this.onOpen,
    required this.onAdd,
  });

  final Bed bed;
  final bool selected;
  final VoidCallback onSelect;
  final VoidCallback onOpen;
  final VoidCallback onAdd;

  String get title {
    return bed.name.trim().isEmpty ? 'Bed ${bed.number}' : bed.name.trim();
  }

  int get placedCount {
    return bed.cropBlocks.length + bed.cropPlacements.length;
  }

  double get healthValue {
    if (bed.healthPercent < 0) return 0;
    if (bed.healthPercent > 1) return 1;
    return bed.healthPercent;
  }

  @override
  Widget build(BuildContext context) {
    final borderColor = selected
        ? Theme.of(context).colorScheme.primary
        : const Color(0xFFD9CDB8);

    return Card(
      elevation: 0,
      color: selected ? const Color(0xFFE8F4E8) : Colors.white,
      clipBehavior: Clip.antiAlias,
      shape: RoundedRectangleBorder(
        borderRadius: BorderRadius.circular(24),
        side: BorderSide(color: borderColor, width: selected ? 2.5 : 1),
      ),
      child: InkWell(
        onTap: onSelect,
        onLongPress: onOpen,
        child: Padding(
          padding: const EdgeInsets.all(14),
          child: Column(
            crossAxisAlignment: CrossAxisAlignment.start,
            children: [
              Row(
                children: [
                  Stack(
                    alignment: Alignment.center,
                    children: [
                      SizedBox(
                        width: 42,
                        height: 42,
                        child: CircularProgressIndicator(
                          value: healthValue,
                          strokeWidth: 5,
                        ),
                      ),
                      const Icon(Icons.yard_outlined, size: 19),
                    ],
                  ),
                  const SizedBox(width: 12),
                  Expanded(
                    child: Text(
                      title,
                      maxLines: 1,
                      overflow: TextOverflow.ellipsis,
                      style: const TextStyle(
                        fontWeight: FontWeight.w900,
                        fontSize: 16,
                      ),
                    ),
                  ),
                  if (selected)
                    const Icon(Icons.check_circle, color: Colors.green),
                ],
              ),
              const SizedBox(height: 12),
              Text(
                '${bed.zone} • ${bed.width.toStringAsFixed(1)}m × ${bed.height.toStringAsFixed(1)}m',
                maxLines: 1,
                overflow: TextOverflow.ellipsis,
                style: const TextStyle(fontSize: 12),
              ),
              const SizedBox(height: 8),
              Wrap(
                spacing: 6,
                runSpacing: 6,
                children: [
                  _MiniChip(label: '${(healthValue * 100).round()}% health'),
                  _MiniChip(label: '$placedCount placed'),
                  _MiniChip(label: '${bed.issues.length} issues'),
                ],
              ),
              const SizedBox(height: 10),
              Expanded(
                child: Container(
                  width: double.infinity,
                  padding: const EdgeInsets.all(10),
                  decoration: BoxDecoration(
                    color: const Color(0xFFF7F2EA),
                    borderRadius: BorderRadius.circular(16),
                    border: Border.all(color: const Color(0xFFE2D6C6)),
                  ),
                  child: bed.crops.isEmpty
                      ? const Center(
                          child: Text(
                            'No crops yet',
                            textAlign: TextAlign.center,
                            style: TextStyle(fontWeight: FontWeight.w700),
                          ),
                        )
                      : SingleChildScrollView(
                          child: Wrap(
                            spacing: 6,
                            runSpacing: 6,
                            children: [
                              for (final crop in bed.crops.take(8))
                                Chip(
                                  visualDensity: VisualDensity.compact,
                                  label: Text(
                                    crop,
                                    overflow: TextOverflow.ellipsis,
                                  ),
                                ),
                            ],
                          ),
                        ),
                ),
              ),
              const SizedBox(height: 10),
              Row(
                children: [
                  Expanded(
                    child: FilledButton.tonal(
                      onPressed: onAdd,
                      child: const FittedBox(
                        fit: BoxFit.scaleDown,
                        child: Text('Add plant'),
                      ),
                    ),
                  ),
                  const SizedBox(width: 8),
                  IconButton.outlined(
                    onPressed: onOpen,
                    icon: const Icon(Icons.info_outline),
                    tooltip: 'Bed details',
                  ),
                ],
              ),
            ],
          ),
        ),
      ),
    );
  }
}

class _MiniChip extends StatelessWidget {
  const _MiniChip({required this.label});

  final String label;

  @override
  Widget build(BuildContext context) {
    return Chip(
      visualDensity: VisualDensity.compact,
      label: Text(
        label,
        style: const TextStyle(fontSize: 11, fontWeight: FontWeight.w800),
      ),
    );
  }
}

class _BedDetailTile extends StatelessWidget {
  const _BedDetailTile({
    required this.icon,
    required this.title,
    required this.value,
  });

  final IconData icon;
  final String title;
  final String value;

  @override
  Widget build(BuildContext context) {
    return Card(
      elevation: 0,
      color: Theme.of(context).colorScheme.surfaceContainerHighest,
      shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(18)),
      child: ListTile(
        leading: Icon(icon),
        title: Text(title, style: const TextStyle(fontWeight: FontWeight.w900)),
        subtitle: Text(value),
      ),
    );
  }
}

class _PortStatusPage extends StatelessWidget {
  const _PortStatusPage({
    required this.statusMessage,
    required this.selectedPlantName,
    required this.bedCount,
    required this.plantedBedCount,
    required this.issueCount,
    required this.onOpenPlanner,
    required this.onOpenPlants,
    required this.onOpenMap,
  });

  final String statusMessage;
  final String? selectedPlantName;
  final int bedCount;
  final int plantedBedCount;
  final int issueCount;
  final VoidCallback onOpenPlanner;
  final VoidCallback onOpenPlants;
  final VoidCallback onOpenMap;

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: const Color(0xFFF7F2EA),
      body: SafeArea(
        child: ListView(
          padding: const EdgeInsets.all(16),
          children: [
            Card(
              elevation: 0,
              color: Colors.white,
              shape: RoundedRectangleBorder(
                borderRadius: BorderRadius.circular(24),
              ),
              child: Padding(
                padding: const EdgeInsets.all(18),
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    const Icon(Icons.phone_android_outlined, size: 34),
                    const SizedBox(height: 12),
                    Text(
                      'Mobile port status',
                      style: Theme.of(context).textTheme.headlineSmall
                          ?.copyWith(fontWeight: FontWeight.w900),
                    ),
                    const SizedBox(height: 8),
                    Text(statusMessage),
                    const SizedBox(height: 14),
                    Chip(
                      avatar: const Icon(Icons.eco_outlined, size: 18),
                      label: Text(
                        selectedPlantName == null
                            ? 'No plant selected'
                            : 'Selected: $selectedPlantName',
                      ),
                    ),
                    const SizedBox(height: 8),
                    Text(
                      '$plantedBedCount/$bedCount beds planted • $issueCount issue records',
                    ),
                    const SizedBox(height: 16),
                    Wrap(
                      spacing: 8,
                      runSpacing: 8,
                      children: [
                        FilledButton.icon(
                          onPressed: onOpenMap,
                          icon: const Icon(Icons.map_outlined),
                          label: const Text('Open map'),
                        ),
                        OutlinedButton.icon(
                          onPressed: onOpenPlants,
                          icon: const Icon(Icons.eco_outlined),
                          label: const Text('Pick plant'),
                        ),
                        OutlinedButton.icon(
                          onPressed: onOpenPlanner,
                          icon: const Icon(Icons.yard_outlined),
                          label: const Text('Planner'),
                        ),
                      ],
                    ),
                  ],
                ),
              ),
            ),
            const SizedBox(height: 12),
            const _StepCard(
              done: true,
              title: 'Mobile shell',
              subtitle: 'Bottom tabs are active.',
              icon: Icons.navigation_outlined,
            ),
            const SizedBox(height: 10),
            const _StepCard(
              done: true,
              title: 'Plant Info',
              subtitle: 'Plant library is mobile-first.',
              icon: Icons.eco_outlined,
            ),
            const SizedBox(height: 10),
            const _StepCard(
              done: true,
              title: 'Map',
              subtitle:
                  'Map tab now uses mobile bed cards instead of the desktop map surface.',
              icon: Icons.map_outlined,
            ),
          ],
        ),
      ),
    );
  }
}

class _StepCard extends StatelessWidget {
  const _StepCard({
    required this.done,
    required this.title,
    required this.subtitle,
    required this.icon,
  });

  final bool done;
  final String title;
  final String subtitle;
  final IconData icon;

  @override
  Widget build(BuildContext context) {
    return Card(
      elevation: 0,
      color: Colors.white,
      shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(20)),
      child: ListTile(
        leading: Icon(done ? Icons.check_circle_outline : icon),
        title: Text(title, style: const TextStyle(fontWeight: FontWeight.w900)),
        subtitle: Text(subtitle),
      ),
    );
  }
}
